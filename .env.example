# Copy to `.env` and fill in. `.env` is gitignored.

# ── claude-code (deno task test:live) ──
# Optional. Leave empty if you're logged in via `claude` — the Agent
# SDK picks up the Claude Code OAuth session from your OS keychain
# (macOS Keychain entry "Claude Code-credentials", or the platform
# equivalent). Set this only to override the CLI session, or when
# running somewhere without `claude` installed. Get one at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# ── resend (deno task resend:send-live) ──
RESEND_API_KEY=re_xxx
# Optional overrides for the live test.
# RESEND_FROM=onboarding@resend.dev
# RESEND_TO=raf@bandeira.tech
# RESEND_SUBJECT=manual smoke

# ── whatsapp (deno task whatsapp:send-live) ──
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_TO=+15555550100
# Optional overrides. Outside the 24h customer-service window only
# template messages deliver — leave WA_TEXT unset to send the
# `hello_world` template Meta ships on every test number.
# WA_TEMPLATE_NAME=hello_world
# WA_TEMPLATE_LANG=en_US
# WA_TEXT=manual smoke
# WA_GRAPH_VERSION=v21.0
