# Optional. Leave empty if you're logged in via `claude` — the Agent
# SDK picks up the Claude Code OAuth session from your OS keychain
# (macOS Keychain entry "Claude Code-credentials", or the platform
# equivalent).
#
# Set this only if you want to override the CLI session, or you're
# running somewhere without `claude` installed. Get one at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=
